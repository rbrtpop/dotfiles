#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
failures=0

pass() {
  printf 'ok  - %s\n' "$1"
}

warn() {
  printf 'warn - %s\n' "$1"
}

fail() {
  printf 'fail - %s\n' "$1" >&2
  failures=$((failures + 1))
}

homebrew_bin() {
  if [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    printf '%s/bin/brew\n' "$HOMEBREW_PREFIX"
  elif [[ -x /opt/homebrew/bin/brew ]]; then
    printf '/opt/homebrew/bin/brew\n'
  elif [[ -x /usr/local/bin/brew ]]; then
    printf '/usr/local/bin/brew\n'
  elif command -v brew >/dev/null 2>&1; then
    command -v brew
  fi
}

check_macos() {
  if [[ "$(uname)" == "Darwin" ]]; then
    pass "running on macOS"
  else
    fail "this setup is only for macOS"
  fi
}

check_homebrew() {
  local brew_cmd

  brew_cmd="$(homebrew_bin || true)"
  if [[ -n "$brew_cmd" ]]; then
    pass "Homebrew found"
    if "$brew_cmd" --prefix >/dev/null 2>&1; then
      pass "Homebrew prefix is usable"
    else
      fail "brew exists but brew --prefix failed"
    fi
  else
    warn "Homebrew not found; ./bin/setup will install it"
  fi
}

check_xcode_command_line_tools() {
  if xcode-select -p >/dev/null 2>&1; then
    pass "Xcode Command Line Tools installed"
  else
    warn "Xcode Command Line Tools missing; ./bin/setup will launch the installer and exit for a rerun"
  fi
}

check_repo_state() {
  if git -C "$repo_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    pass "dotfiles git repo detected"
  else
    fail "not inside a git repo"
  fi

  if [[ -f "${repo_root}/Brewfile" ]]; then
    pass "Brewfile present"
  else
    fail "Brewfile missing"
  fi

  if [[ -f "${repo_root}/home/.config/mise/config.toml" ]]; then
    pass "mise config present"
  else
    fail "mise config missing"
  fi
}

check_nvim_source() {
  if [[ -d "${repo_root}/nvim" ]] && find "${repo_root}/nvim" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
    pass "nvim source present"
  else
    warn "nvim source missing or empty; link-dotfiles will skip ~/.config/nvim"
  fi
}

check_script_syntax() {
  local script
  local scripts=(
    "bin/setup"
    "bin/preflight"
    "bin/link-dotfiles"
    "bin/check-mise-tools"
    "bin/auth-setup"
    "bin/configure-sudo-touch-id"
    "bin/setup-tmux"
    "bin/ensure-mise-standalone"
    "bin/ensure-codex-standalone"
    "bin/dotfiles-update"
  )

  for script in "${scripts[@]}"; do
    if [[ -f "${repo_root}/${script}" ]]; then
      if bash -n "${repo_root}/${script}"; then
        pass "syntax: ${script}"
      else
        fail "syntax error: ${script}"
      fi
    else
      fail "missing script: ${script}"
    fi
  done
}

check_macos
check_xcode_command_line_tools
check_homebrew
check_repo_state
check_nvim_source
check_script_syntax

if [[ $failures -gt 0 ]]; then
  printf '\nPreflight failed with %s issue(s).\n' "$failures" >&2
  exit 1
fi

printf '\nPreflight passed.\n'
